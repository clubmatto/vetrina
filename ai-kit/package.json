{
  "name": "ai-kit",
  "version": "0.0.1",
  "description": "Use Club Matto's AI configuration in your projects.",
  "type": "module",
  "bin": {
    "ai-kit": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:link": "npm run build && npm link",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:integration": "npm run build && vitest run tests/integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prettier:write": "prettier --write .",
    "prettier:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint . && knip",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run test:integration"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.6",
    "eslint": "^10.0.1",
    "knip": "^5.84.1",
    "prettier": "^3.4.2",
    "tsx": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "club-matto",
    "ai",
    "cli"
  ],
  "license": "MIT"
}
